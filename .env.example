# Postgres connection string. Works with Vercel Postgres, Supabase, Neon, or local.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Long random string used to gate /admin actions (db setup, seeding, Literal
# import). Generate one with: openssl rand -hex 32
# If unset, all /api/admin/* routes return 503 — set it before first deploy.
ADMIN_TOKEN=change-me-to-a-long-random-string

# Optional default for the Literal book import. Override per-call from /admin.
LITERAL_HANDLE=ron
