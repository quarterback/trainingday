# Postgres connection string. Works with Vercel Postgres, Supabase, Neon, or local.
DATABASE_URL=postgres://user:password@host:5432/dbname

# Single-user password gate. Anything you'll remember.
APP_PASSWORD=change-me

# HMAC secret used to sign auth cookies. Generate with: openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-hex-string
